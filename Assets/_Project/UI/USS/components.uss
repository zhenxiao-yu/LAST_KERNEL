/*
 * components.uss — Full component library for LAST KERNEL
 *
 * Class convention: .lk-<component>[__<part>][--<modifier>]
 * Every transition is defined inline with its component (not split to animations.uss).
 * No hardcoded colors — always var(--lk-*).
 * Pixel-art rules: border-radius always 0, no gradients, integer sizes.
 */

/* ════════════════════════════════════════════════════════════════════════
 * Screen root
 * Full-screen background layer. Apply to the UXML root VisualElement.
 * ════════════════════════════════════════════════════════════════════════ */

.lk-screen-bg {
    background-color: var(--lk-bg);
}

.lk-screen--transparent {
    background-color: var(--lk-transparent);
}

/* Full-screen black overlay for scene transitions. Opacity driven by ScreenFaderController. */
.lk-screen-fader {
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
    background-color: rgb(0, 0, 0);
    opacity: 0;
}

/* Semi-transparent overlay — use with .lk-screen for in-game overlays (e.g. pause) */
.lk-screen--overlay {
    background-color: var(--lk-overlay-bg);
}

/* Pause menu overlay — deeper than generic overlay, nearly opaque */
.lk-screen--pause {
    background-color: rgba(2, 3, 8, 0.97);
}

/* Vignette — inset border darkening on all edges; first child of its container for lowest z-order */
.lk-vignette {
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
    border-top-width: 120px;
    border-bottom-width: 120px;
    border-left-width: 80px;
    border-right-width: 80px;
    border-color: rgba(0, 0, 0, 0.7);
    background-color: rgba(0, 0, 0, 0);
    pointer-events: none;
}

/* ════════════════════════════════════════════════════════════════════════
 * Panel
 * ════════════════════════════════════════════════════════════════════════ */

.lk-panel {
    background-color: var(--lk-panel);
    border-color: var(--lk-border-dim);
    border-width: 1px;
    border-radius: 0;
    padding: var(--lk-padding-medium);
    flex-direction: column;
}

/* Accent border — active, selected, or primary panel */
.lk-panel--accent {
    border-color: var(--lk-border);
}

/* Deep inset surface — secondary panels inside a panel */
.lk-panel--inset {
    background-color: var(--lk-panel-overlay);
    border-color: var(--lk-border-dim);
}

/* Panel header — left accent bar + column layout for title + subtitle */
.lk-panel__header {
    flex-direction: column;
    align-items: flex-start;
    border-left-color: var(--lk-accent);
    border-left-width: 4px;
    border-bottom-color: var(--lk-border-dim);
    border-bottom-width: 1px;
    padding-left: var(--lk-padding-medium);
    padding-bottom: var(--lk-padding-medium);
    margin-bottom: var(--lk-gap-medium);
    background-color: rgba(0, 220, 255, 0.04);
}

.lk-panel__title {
    color: var(--lk-accent);
    font-size: var(--lk-font-size-title);
    -unity-font-style: bold;
    white-space: nowrap;
    text-shadow: 0px 0px 6px rgba(0, 220, 255, 0.35), 0px 1px 2px rgba(0, 0, 0, 0.95);
}

/* Tagline beneath the panel title — uppercase, dim, letter-spaced */
.lk-panel__subtitle {
    color: var(--lk-text-dim);
    font-size: var(--lk-font-size-xs);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-top: 4px;
    white-space: nowrap;
    opacity: 0.8;
}

.lk-panel__footer {
    flex-direction: row;
    justify-content: flex-end;
    border-top-color: var(--lk-border-dim);
    border-top-width: 1px;
    padding-top: var(--lk-gap-medium);
    margin-top: var(--lk-gap-medium);
}

.lk-panel__footer--flush {
    margin-top: 0;
}

.lk-panel__footer--wide-gap {
    gap: var(--lk-gap-medium);
}

.lk-panel__header--compact {
    flex-direction: row;
    align-items: center;
    margin-bottom: 0;
    padding: 12px 16px;
}

.lk-panel__header.lk-panel-header-row {
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-start;
}

.lk-panel__header.lk-panel-header-stack {
    flex-direction: column;
    align-items: stretch;
}

.lk-panel__title--grow {
    flex-grow: 1;
}

.lk-panel--danger {
    border-color: var(--lk-danger-line);
    border-left-color: var(--lk-danger);
}

.lk-panel.lk-panel--pad-none {
    padding: 0;
}

/* ════════════════════════════════════════════════════════════════════════
 * Modal
 * Overlay backdrop + centred dialog.
 * ════════════════════════════════════════════════════════════════════════ */

.lk-modal-backdrop {
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
    background-color: var(--lk-overlay-bg);
    align-items: center;
    justify-content: center;
    pointer-events: auto;
}

.lk-keybind-backdrop {
    background-color: var(--lk-scrim-soft);
    pointer-events: auto;
}

.lk-modal {
    background-color: var(--lk-panel);
    border-color: var(--lk-border);
    border-width: 1px;
    border-radius: 0;
    padding: var(--lk-padding-large);
    min-width: 480px;
    max-width: 720px;
    flex-direction: column;
}

.lk-modal__title {
    color: var(--lk-text-header);
    font-size: var(--lk-font-size-xl);
    -unity-font-style: bold;
    margin-bottom: var(--lk-gap-medium);
    white-space: normal;
    text-shadow: 0px 1px 4px rgba(0, 0, 0, 0.9);
}

.lk-modal__body {
    color: var(--lk-text);
    font-size: var(--lk-font-size-md);
    white-space: normal;
    line-height: 1.5;
    margin-bottom: var(--lk-padding-large);
}

.lk-modal__actions {
    flex-direction: row;
    justify-content: flex-end;
}

.lk-modal__actions .lk-button {
    margin-left: var(--lk-gap-small);
}

/* ════════════════════════════════════════════════════════════════════════
 * Button
 * Outlined by default. Variants via modifier classes.
 * ════════════════════════════════════════════════════════════════════════ */

.lk-button {
    background-color: rgba(0, 0, 0, 0);
    background-image: none;
    -unity-background-image-tint-color: rgba(0, 0, 0, 0);
    border-color: var(--lk-border-dim);
    border-width: 1px;
    border-radius: 0;
    color: var(--lk-text);
    font-size: var(--lk-font-size-md);
    padding-left: var(--lk-padding-medium);
    padding-right: var(--lk-padding-medium);
    padding-top: var(--lk-padding-small);
    padding-bottom: var(--lk-padding-small);
    min-height: var(--lk-touch-min);
    -unity-text-align: middle-center;
    text-transform: uppercase;
    transition-property: border-color, color, background-color;
    transition-duration: var(--lk-transition-fast);
    transition-timing-function: linear;
}

.lk-button:hover {
    border-color: var(--lk-border);
    color: var(--lk-text-header);
    background-color: var(--lk-accent-faint);
    background-image: none;
    -unity-background-image-tint-color: rgba(0, 0, 0, 0);
}

.lk-button:active {
    border-color: var(--lk-accent);
    color: var(--lk-accent);
    background-color: rgba(0, 140, 170, 0.2);
    background-image: none;
    -unity-background-image-tint-color: rgba(0, 0, 0, 0);
}

/* Primary — filled accent, main call-to-action */
.lk-button--primary {
    background-color: var(--lk-accent-dim);
    border-color: var(--lk-accent);
    color: var(--lk-bg);
    -unity-font-style: bold;
}

.lk-button--primary:hover {
    background-color: var(--lk-accent);
    border-color: var(--lk-accent);
    color: var(--lk-bg);
}

.lk-button--primary:active {
    background-color: var(--lk-border);
    color: var(--lk-bg);
}

/* Danger — destructive action */
.lk-button--danger {
    border-color: var(--lk-danger-line);
    color: var(--lk-danger);
}

.lk-button--danger:hover {
    border-color: var(--lk-danger);
    background-color: var(--lk-danger-faint);
    color: var(--lk-warning);
}

/* Text-only nav button — left-border accent slides in on hover */
.lk-button--text {
    border-width: 0;
    border-left-width: 3px;
    border-left-color: rgba(0, 0, 0, 0);
    background-color: rgba(0, 0, 0, 0);
    color: var(--lk-text);
    padding-left: var(--lk-padding-small);
    padding-right: 0;
    min-width: 180px;
    font-size: var(--lk-font-size-lg);
    -unity-text-align: middle-left;
    transition-property: color, border-left-color;
    transition-duration: var(--lk-transition-fast);
    transition-timing-function: linear;
}

.lk-button--text:hover {
    color: var(--lk-accent);
    background-color: rgba(0, 0, 0, 0);
    border-left-color: var(--lk-accent);
}

.lk-button--text:active {
    color: var(--lk-text-header);
    background-color: rgba(0, 0, 0, 0);
    border-left-color: var(--lk-accent-dim);
}

/* Icon-only square button */
.lk-button--icon {
    min-width: var(--lk-touch-min);
    min-height: var(--lk-touch-min);
    padding: var(--lk-padding-small);
    -unity-text-align: middle-center;
}

/* Disabled state — apply in addition to any variant */
.lk-button--disabled {
    border-color: var(--lk-disabled);
    color: var(--lk-disabled);
    background-color: rgba(0, 0, 0, 0);
    opacity: 0.55;
    transition-duration: 0ms;
}

.lk-button--disabled:hover,
.lk-button--disabled:active {
    border-color: var(--lk-disabled);
    color: var(--lk-disabled);
    background-color: rgba(0, 0, 0, 0);
}

/* ════════════════════════════════════════════════════════════════════════
 * Labels
 * ════════════════════════════════════════════════════════════════════════ */

.lk-label {
    color: var(--lk-text);
    font-size: var(--lk-font-size-md);
    white-space: normal;
    line-height: 1.35;
}

/* Logo icon — sprite slot above logo text, hidden until assigned in C# */
.lk-logo-icon {
    display: none;
    width: 72px;
    height: 72px;
    -unity-background-scale-mode: scale-to-fit;
    margin-bottom: var(--lk-gap-small);
    flex-shrink: 0;
}

.lk-logo-icon--visible {
    display: flex;
}

/* Game logo — title screen only */
.lk-label--logo {
    color: var(--lk-accent);
    font-size: var(--lk-font-size-logo);
    -unity-font-style: bold;
    letter-spacing: 4px;
    text-transform: uppercase;
    white-space: nowrap;
    text-shadow: 0px 0px 24px rgba(0, 220, 255, 0.55), 0px 2px 6px rgba(0, 0, 0, 0.95);
}

/* Screen / section title */
.lk-label--title {
    color: var(--lk-accent);
    font-size: var(--lk-font-size-title);
    -unity-font-style: bold;
    text-transform: uppercase;
    white-space: nowrap;
    text-shadow: 0px 0px 12px rgba(0, 220, 255, 0.4), 0px 2px 4px rgba(0, 0, 0, 0.9);
}

/* Panel or section header */
.lk-label--header {
    color: var(--lk-text-header);
    font-size: var(--lk-font-size-xl);
    -unity-font-style: bold;
    text-shadow: 0px 1px 4px rgba(0, 0, 0, 0.85);
}

/* Sub-section / category header */
.lk-label--subheader {
    color: var(--lk-accent-dim);
    font-size: var(--lk-font-size-xs);
    -unity-font-style: bold;
    text-transform: uppercase;
    letter-spacing: 1px;
}

/* Body copy — default */
.lk-label--body {
    color: var(--lk-text);
    font-size: var(--lk-font-size-md);
    white-space: normal;
    line-height: 1.5;
}

/* Secondary / muted */
.lk-label--dim {
    color: var(--lk-text-dim);
    font-size: var(--lk-font-size-xs);
    white-space: normal;
    line-height: 1.35;
}

/* Fine-print hint — sits below an interactive control as a context note */
.lk-hint {
    font-size: var(--lk-font-size-xs);
    color: var(--lk-text-dim);
    white-space: normal;
    line-height: 1.5;
    padding-left: 4px;
    padding-bottom: 8px;
}

/* High-contrast numeric value (HUD counters, costs) */
.lk-label--value {
    color: var(--lk-text-header);
    font-size: var(--lk-font-size-lg);
    -unity-font-style: bold;
    -unity-text-align: middle-right;
    white-space: nowrap;
    min-width: 0;
    text-shadow: 0px 1px 3px rgba(0, 0, 0, 0.8);
}

/* Status variants — swap in via C# when threshold crossed */
.lk-label--accent  { color: var(--lk-accent);   }
.lk-label--warning { color: var(--lk-warning);  }
.lk-label--danger  { color: var(--lk-danger);   }
.lk-label--success { color: var(--lk-success);  }

.lk-text-center {
    -unity-text-align: middle-center;
}

.lk-text-wrap {
    white-space: normal;
}

.lk-text-micro-hint {
    font-size: 10px;
    opacity: 0.4;
    -unity-font-style: italic;
}

/* ════════════════════════════════════════════════════════════════════════
 * Divider
 * ════════════════════════════════════════════════════════════════════════ */

.lk-divider {
    height: 1px;
    background-color: var(--lk-border-dim);
    flex-shrink: 0;
    margin-top: var(--lk-gap-small);
    margin-bottom: var(--lk-gap-small);
}

.lk-divider--accent {
    background-color: var(--lk-border);
}

.lk-divider--danger {
    background-color: var(--lk-danger-line);
}

/* ════════════════════════════════════════════════════════════════════════
 * Progress bar
 * A VisualElement (.lk-progress-bar) containing a child (.lk-progress-bar__fill).
 * Set fill width from C# as a percentage or absolute value.
 * ════════════════════════════════════════════════════════════════════════ */

.lk-progress-bar {
    height: 8px;
    background-color: var(--lk-border-dim);
    border-color: var(--lk-border-dim);
    border-width: 1px;
    border-radius: 0;
    overflow: hidden;
    flex-direction: row;
    flex-shrink: 0;
}

.lk-progress-bar__fill {
    height: 100%;
    background-color: var(--lk-accent);
    flex-shrink: 0;
    transition-property: width;
    transition-duration: var(--lk-transition-normal);
    transition-timing-function: linear;
}

.lk-progress-bar__fill--warning { background-color: var(--lk-warning); }
.lk-progress-bar__fill--danger  { background-color: var(--lk-danger);  }

/* Thicker variant for base HP bar in NightHUD */
.lk-progress-bar--thick {
    height: 14px;
}

.lk-progress-bar.lk-h-6 {
    height: 6px;
}

/* ════════════════════════════════════════════════════════════════════════
 * Resource counter  (icon + value label pair used in CardStatsUI / HUD)
 * ════════════════════════════════════════════════════════════════════════ */

.lk-resource-counter {
    flex-direction: row;
    align-items: center;
    min-height: var(--lk-touch-min);
    padding-left: var(--lk-padding-small);
    padding-right: var(--lk-padding-small);
}

.lk-resource-counter__icon {
    margin-right: 14px;
    flex-shrink: 0;
    -unity-background-scale-mode: scale-to-fit;
}

.lk-resource-counter__value {
    color: var(--lk-text-header);
    font-size: var(--lk-font-size-lg);
    -unity-font-style: bold;
    -unity-text-align: middle-left;
    min-width: 40px;
    white-space: nowrap;
}

.lk-resource-counter--warning .lk-resource-counter__value { color: var(--lk-warning); }
.lk-resource-counter--danger  .lk-resource-counter__value { color: var(--lk-danger);  }

/* ════════════════════════════════════════════════════════════════════════
 * HUD strip  (DayHUD / NightHUD outer containers)
 * ════════════════════════════════════════════════════════════════════════ */

.lk-hud-strip {
    flex-direction: row;
    align-items: center;
    min-height: var(--lk-hud-height);
    background-color: var(--lk-hud-bg);
    padding-left: var(--lk-padding-medium);
    padding-right: var(--lk-padding-medium);
}

.lk-hud-strip--top {
    border-bottom-color: var(--lk-border);
    border-bottom-width: 2px;
}

.lk-hud-strip--bottom {
    border-top-color: var(--lk-border-dim);
    border-top-width: 1px;
}

/* Night-phase urgency tint */
.lk-hud-strip--night {
    background-color: rgba(20, 6, 6, 0.96);
    border-bottom-color: rgba(204, 46, 46, 0.65);
    border-bottom-width: 3px;
}

/* Phase label (DAY / NIGHT) */
.lk-phase-label {
    color: var(--lk-accent);
    font-size: var(--lk-font-size-xl);
    -unity-font-style: bold;
    -unity-text-align: middle-center;
    letter-spacing: 2px;
    white-space: nowrap;
    text-shadow: 0px 0px 10px rgba(0, 220, 255, 0.5);
}

.lk-phase-label--night   { color: var(--lk-accent-secondary); }
.lk-phase-label--danger  { color: var(--lk-danger); }

/* ════════════════════════════════════════════════════════════════════════
 * Info panel  (InfoPanel.cs — priority-queued context display)
 * ════════════════════════════════════════════════════════════════════════ */

.lk-info-panel {
    background-color: var(--lk-panel-overlay);
    border-color: var(--lk-border-dim);
    border-width: 1px;
    border-left-color: var(--lk-accent);
    border-left-width: 4px;
    border-top-color: rgba(0, 220, 255, 0.22);
    border-top-width: 1px;
    border-radius: 0;
    padding: 12px var(--lk-padding-small) 12px var(--lk-padding-medium);
    flex-direction: column;
    gap: 4px;
}

.lk-info-panel__header {
    color: var(--lk-text-header);
    font-size: var(--lk-font-size-card);
    -unity-font-style: bold;
    margin-bottom: 0;
    white-space: nowrap;
    overflow: hidden;
    -unity-text-overflow-position: End;
    flex-grow: 1;
    min-width: 0;
    text-shadow: 0px 0px 6px rgba(0, 220, 255, 0.24), 0px 1px 2px rgba(0, 0, 0, 0.9);
}

.lk-info-panel__body {
    color: var(--lk-text);
    font-size: var(--lk-font-size-sm);
    white-space: normal;
    line-height: 1.55;
}

.lk-info-card {
    flex-direction: column;
    background-color: rgba(2, 5, 12, 0.42);
    border-top-color: rgba(0, 220, 255, 0.18);
    border-top-width: 1px;
    padding-top: 10px;
    padding-bottom: 4px;
}

.lk-info-section {
    flex-direction: column;
    margin-top: 8px;
    border-left-color: rgba(0, 220, 255, 0.22);
    border-left-width: 2px;
    padding-left: 10px;
}

.lk-info-section__toggle {
    min-height: 28px;
    padding-left: 0;
    padding-right: 8px;
    padding-top: 3px;
    padding-bottom: 3px;
    background-color: rgba(0, 0, 0, 0);
    border-width: 0;
    border-bottom-color: rgba(0, 220, 255, 0.10);
    border-bottom-width: 1px;
    color: var(--lk-text-dim);
    -unity-font-style: bold;
    -unity-text-align: middle-left;
    font-size: var(--lk-font-size-xs);
    letter-spacing: 1px;
    text-transform: uppercase;
    transition-property: color, background-color, border-bottom-color;
    transition-duration: var(--lk-transition-fast);
    transition-timing-function: linear;
}

.lk-info-section__toggle:hover {
    color: var(--lk-accent);
    background-color: rgba(0, 220, 255, 0.06);
    border-bottom-color: rgba(0, 220, 255, 0.28);
}

.lk-info-section__content {
    margin-top: 4px;
    padding-bottom: 4px;
    white-space: normal;
    line-height: 1.45;
}

/* ── Info panel title bar ───────────────────────────────────────────────────
 * Full-width header row inside .lk-info-panel.
 * Contains: [INFO] prefix | header label (flex-grow) | category badge | type chip
 * ─────────────────────────────────────────────────────────────────────────── */

.lk-info-panel__titlebar {
    flex-direction: row;
    align-items: center;
    background-color: rgba(0, 220, 255, 0.06);
    border-bottom-color: rgba(0, 220, 255, 0.22);
    border-bottom-width: 1px;
    /* bleed beyond panel padding to reach left accent border and right edge */
    margin-top: -12px;
    margin-left: -16px;
    margin-right: -8px;
    margin-bottom: var(--lk-gap-small);
    /* restore visual indent matching panel's original content position */
    padding: 10px var(--lk-padding-small) 10px var(--lk-padding-medium);
    gap: 14px;
    min-height: 52px;
    flex-shrink: 0;
}

/* [INFO] / [SYS] terminal-style prefix badge */
.lk-info-panel__prefix {
    color: var(--lk-accent-dim);
    font-size: 11px;
    letter-spacing: 1px;
    white-space: nowrap;
    flex-shrink: 0;
    opacity: 0.68;
}

/* HP bar row — terminal stat readout */
.lk-info-hp-row {
    flex-direction: row;
    align-items: center;
    margin-top: 10px;
    margin-bottom: 4px;
    gap: 14px;
    padding: 8px 12px;
    background-color: rgba(204, 46, 46, 0.06);
    border-left-color: var(--lk-danger);
    border-left-width: 3px;
    min-height: 40px;
}

/* "HP 12 / 20" label */
.lk-info-hp-label {
    color: var(--lk-danger);
    font-size: var(--lk-font-size-sm);
    -unity-font-style: bold;
    min-width: 72px;
    flex-shrink: 0;
    white-space: nowrap;
}

/* Chips cluster row: sell / food / uses — flex-wrap so they never overflow */
.lk-info-chips-row {
    flex-direction: row;
    flex-wrap: wrap;
    gap: 4px;
    margin-top: 6px;
    align-items: center;
}

/* Info section header row — icon slot + toggle button on same line */
.lk-info-section__header {
    flex-direction: row;
    align-items: center;
    gap: 12px;
    min-height: 32px;
}

/* ════════════════════════════════════════════════════════════════════════
 * Icon slot system
 *
 * HOW TO INTEGRATE SPRITES IN ONE PROMPT:
 *   1. Download white-on-transparent PNGs from the pack listed below each slot.
 *   2. Import to Assets/_Project/UI/Icons/
 *        Texture Type: Sprite (2D and UI)
 *        Filter Mode: Point  (pixel-art, no blur)
 *        Compression: None
 *   3. For each slot, uncomment the background-image line and replace
 *      REPLACE_GUID with the guid from the icon's .meta file. Remove the
 *      placeholder background-color line at the same time.
 *
 *        background-image: url("project://database/Assets/_Project/UI/Icons/ICON.png?fileID=2800000&guid=YOUR_GUID&type=3#ICON");
 *
 * RECOMMENDED FREE PACKS:
 *   ① game-icons.net  CC BY 3.0  4 400+ game icons — resources, weapons,
 *                     creatures, symbols. Download as PNG: choose white icon +
 *                     transparent background before downloading.
 *                     Best for: resource HUD, card categories, combat icons.
 *
 *   ② kenney.nl/assets  CC0  Pixel-art UI packs (Game Icons, Input Prompts).
 *                     Best for: info/close/chevron/settings HUD chrome.
 *                     Download the "Game Icons" pack and "UI Pack".
 *
 * BASE PATTERN:
 *   All sprites are white. Color is applied via -unity-background-image-tint-color.
 *   The placeholder border + background-color shows until the sprite is added.
 * ════════════════════════════════════════════════════════════════════════ */

/* Base slot — point-sampled, white-tint-ready */
.lk-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    -unity-background-scale-mode: scale-to-fit;
    background-color: rgba(0, 0, 0, 0);
    border-width: 0;
}

.lk-icon--sm { width: 16px; height: 16px; }
.lk-icon--lg { width: 24px; height: 24px; }
.lk-icon--xl { width: 32px; height: 32px; }
.lk-icon.lk-icon-28 { width: 28px; height: 28px; }

/* ── Info panel icons ─────────────────────────────────────────────── */

/* delapouite/info.png */
.lk-icon--info {
    background-image: url("project://database/Assets/_Project/Art/UI/Icons/1x1/delapouite/info.png?fileID=2800000&guid=f9fd52feb72bd6342bd1081bf3c68ff9&type=3#info");
