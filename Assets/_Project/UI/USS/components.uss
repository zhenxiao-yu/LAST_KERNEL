    background-image: url("project://database/Assets/_Project/Art/UI/Icons/1x1/delapouite/exit-door.png?fileID=2800000&guid=049dbbc0b3776ba4c9e5f46784d6d01b&type=3#exit-door");
    -unity-background-image-tint-color: var(--lk-danger);
